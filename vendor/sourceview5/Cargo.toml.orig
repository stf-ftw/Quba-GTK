[package]
authors.workspace = true
edition.workspace = true
name = "sourceview5"
version.workspace = true
readme = "./../README.md"
license.workspace = true
homepage.workspace = true
documentation = "https://world.pages.gitlab.gnome.org/Rust/sourceview5-rs/stable/latest/docs/sourceview5"
repository.workspace = true
categories.workspace = true
keywords.workspace = true
description = "Rust bindings for GtkSourceView 5"

[features]
default = []
gtk_v4_6 = ["gtk/v4_6", "pango/v1_50"]
gtk_v4_12 = ["gtk/v4_12"]
gtk_v4_14 = ["gtk/v4_14"]
gtk_v4_18 = ["gtk/v4_18"]
v5_2 = ["ffi/v5_2"]
v5_4 = ["v5_2", "ffi/v5_4", "gtk_v4_6"]
v5_6 = ["v5_4", "ffi/v5_6"]
v5_10 = ["v5_6", "ffi/v5_10"]
v5_12 = ["v5_10", "ffi/v5_12"]
v5_16 = ["v5_12", "ffi/v5_16"]
v5_18 = ["v5_16", "ffi/v5_18"]

[package.metadata.docs.rs]
all-features = true
rustdoc-args = ["--generate-link-to-definition"]

[dependencies]
libc = "0.2"
futures-core = { version = "0.3", default-features = false }
futures-channel = "0.3"

[dependencies.gtk]
git = "https://github.com/gtk-rs/gtk4-rs.git"
package = "gtk4"
branch = "0.11"
version = "0.11"

[dependencies.gdk]
git = "https://github.com/gtk-rs/gtk4-rs.git"
package = "gdk4"
branch = "0.11"
version = "0.11"

[dependencies.glib]
git = "https://github.com/gtk-rs/gtk-rs-core.git"
branch = "0.22"
version = "0.22"

[dependencies.pango]
git = "https://github.com/gtk-rs/gtk-rs-core.git"
branch = "0.22"
version = "0.22"

[dependencies.gdk-pixbuf]
git = "https://github.com/gtk-rs/gtk-rs-core.git"
branch = "0.22"
version = "0.22"

[dependencies.gio]
git = "https://github.com/gtk-rs/gtk-rs-core.git"
branch = "0.22"
version = "0.22"

[dependencies.ffi]
package = "sourceview5-sys"
path = "./sys"
version = "0.11"
