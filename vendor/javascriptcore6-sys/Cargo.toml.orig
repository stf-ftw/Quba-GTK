[package]
name = "javascriptcore6-sys"
build = "build.rs"
description = "FFI bindings for JavaScriptCore 6"
documentation = "https://world.pages.gitlab.gnome.org/Rust/webkit6-rs/stable/latest/docs/javascriptcore6_sys"

[package.version]
workspace = true

[package.edition]
workspace = true

[package.authors]
workspace = true

[package.categories]
workspace = true

[package.repository]
workspace = true

[package.license]
workspace = true

[package.keywords]
workspace = true

[package.exclude]
workspace = true

[package.metadata.system-deps.javascriptcoregtk_6_0]
name = "javascriptcoregtk-6.0"
version = "2.40.0"

[package.metadata.system-deps.javascriptcoregtk_6_0.v2_48]
version = "2.48"

[package.metadata.docs.rs]
all-features = true
rustdoc-args = ["--generate-link-to-definition"]

[dependencies]
libc = "0.2"

[dependencies.glib-sys]
workspace = true

[dependencies.gobject-sys]
workspace = true

[build-dependencies]
system-deps = "7"

[dev-dependencies]
shell-words = "1.0.0"
tempfile = "3"

[features]
v2_48 = []
