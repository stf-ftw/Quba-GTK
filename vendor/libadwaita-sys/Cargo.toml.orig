[package]
name = "libadwaita-sys"
build = "build.rs"
description = "FFI bindings for libadwaita"
documentation = "https://world.pages.gitlab.gnome.org/Rust/libadwaita-rs/stable/latest/docs/libadwaita_sys"

[package.version]
workspace = true

[package.categories]
workspace = true

[package.keywords]
workspace = true

[package.authors]
workspace = true

[package.edition]
workspace = true

[package.license]
workspace = true

[package.homepage]
workspace = true

[package.repository]
workspace = true

[package.metadata.system-deps.libadwaita_1]
name = "libadwaita-1"
version = "1"

[package.metadata.system-deps.libadwaita_1.v1_1]
version = "1.1"

[package.metadata.system-deps.libadwaita_1.v1_2]
version = "1.2"

[package.metadata.system-deps.libadwaita_1.v1_3]
version = "1.3"

[package.metadata.system-deps.libadwaita_1.v1_4]
version = "1.4"

[package.metadata.system-deps.libadwaita_1.v1_5]
version = "1.5"

[package.metadata.system-deps.libadwaita_1.v1_6]
version = "1.6"

[package.metadata.system-deps.libadwaita_1.v1_7]
version = "1.7"

[package.metadata.system-deps.libadwaita_1.v1_8]
version = "1.8"

[package.metadata.system-deps.libadwaita_1.v1_9]
version = "1.9"

[package.metadata.docs.rs]
all-features = true
rustdoc-args = ["--generate-link-to-definition"]

[lib]
name = "libadwaita_sys"

[dependencies]
libc = "0.2"

[dependencies.gio-sys]
git = "https://github.com/gtk-rs/gtk-rs-core"
branch = "0.22"
version = "0.22"

[dependencies.glib-sys]
git = "https://github.com/gtk-rs/gtk-rs-core"
branch = "0.22"
version = "0.22"

[dependencies.gobject-sys]
git = "https://github.com/gtk-rs/gtk-rs-core"
branch = "0.22"
version = "0.22"

[dependencies.gtk-sys]
package = "gtk4-sys"
git = "https://github.com/gtk-rs/gtk4-rs"
branch = "0.11"
version = "0.11"

[dependencies.gdk-sys]
package = "gdk4-sys"
git = "https://github.com/gtk-rs/gtk4-rs"
branch = "0.11"
version = "0.11"

[dependencies.pango-sys]
git = "https://github.com/gtk-rs/gtk-rs-core"
branch = "0.22"
version = "0.22"

[build-dependencies]
system-deps = "7"

[dev-dependencies]
shell-words = "1.0.0"
tempfile = "3"

[features]
v1_1 = []
v1_2 = ["v1_1"]
v1_3 = ["v1_2"]
v1_4 = ["v1_3"]
v1_5 = ["v1_4"]
v1_6 = ["v1_5"]
v1_7 = ["v1_6"]
v1_8 = ["v1_7"]
v1_9 = ["v1_8"]
